class Solution {
    public boolean canAliceWin(int[] nums) {
        int d = 0;
        int s = 0;
        for (int i = 0; i < nums.length; i++){
            
            if (nums[i] > 9){
                s = s + nums[i];
            }
            else{
                s = s - nums[i];
            }
        }
        if (s == 0) return false;
        else return true;
    }
}
