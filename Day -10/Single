class Animal{
    void eat(){
        System.out.println("animal is eating");
    }
}

class Puppy extends Animal{
    void play(){
        System.out.println("puppy is playing");
    }

}
public class Main{
    public static void main(String[] args){
        Puppy p=new Puppy();
        p.eat();
   
        p.play();
    }
}
