import java.util.*;
public class Main
{
	public static void main(String[] args) {
		List<Integer> list=new ArrayList<>();
		System.out.println("add the elements");
		list.add(11);
		list.add(12);
		list.add(13);
		list.add(15);
		System.out.println(list);
		System.out.println("delete the elements: ");
		list.remove(2);
		System.out.println(list);
		System.out.println("access the element");
		System.out.println(list.get(2));
		System.out.println("update the elements: ");
		list.set(2,14);
		System.out.println(list);
		System.out.println("traversal the element");
		for(int x: list){
		    System.out.println(x+" ");
		}
	}
}
